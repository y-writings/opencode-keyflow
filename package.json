{
  "name": "opencode-keyflow",
  "version": "0.3.0",
  "description": "OpenCode TUI plugin for keybind-driven built-in command sequences",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "keyflow.json",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun && bunx tsc --emitDeclarationOnly --outDir ./dist",
    "typecheck": "bunx tsc --noEmit"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.31"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.31",
    "@opentui/core": "^0.2.1",
    "@opentui/solid": "^0.2.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tui": "./src/index.ts"
  }
}
